@page "/sessions/{sessionId}/chat"
@using System.Text.Json
@using Edgar.Service.Ollama
@using Edgar.Service.Sessions
@inject IChatRepository ChatRepository
<h3>@SessionId</h3>



<table class="table table-striped table-sm table-bordered">
    <thead>
    <tr>
        <th>Date</th>
        <th>Role</th>
        <th>Content</th>
        <th>Tool Name</th>
        <th>Tool Calls</th>
    </tr>
    </thead>
    <tbody>
    @if (!Messages.Any())
    {
        <tr><td colspan="4">No messages</td></tr>
    }
    @foreach (var message in Messages)
    {
        var parsed = Parse(message);
        if (parsed is null) continue;
        <tr>
            <td>@parsed.CreatedAt</td>
            <td>@parsed.Role</td>
            <td>@parsed.Content</td>
            <td>@parsed.ToolName</td>
            <td>
                @if (parsed.ToolCalls is not null && parsed.ToolCalls.Any())
                {
                    <ul>
                        @foreach (var toolCall in parsed.ToolCalls)
                        {
                            <li>@toolCall.Function.Index</li>
                            <li>@toolCall.Function.Name</li>
                            <li>@JsonSerializer.Serialize(toolCall.Function.Arguments)</li>
                        }
                    </ul>
                }
            </td>
        </tr>
    }
    </tbody>
</table>

@code {
    [Parameter] public required string SessionId { get; set; }

    private IEnumerable<string> Messages { get; set; } = [];

    private OllamaChatMessage? Parse(string value)
    {
        try
        {
            return JsonSerializer.Deserialize<OllamaChatMessage>(value);
        }
        catch (Exception e)
        {
            return null;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        Messages = await ChatRepository.GetChatLog(Guid.Parse(SessionId));
    }

}